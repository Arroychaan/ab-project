// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== AUTH — Multi Admin =====
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // bcrypt hashed
  role      String   @default("ADMIN") // ADMIN or SUPER_ADMIN
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== CONTENT — Per Page =====
model Page {
  id         String   @id @default(cuid())
  slug       String   @unique // "sambutan", "sejarah", "visi-misi", "unit", "agenda", atau bebas
  title      String
  subtitle   String?
  layout     String   @default("STANDARD") // "STANDARD", "HERO_IMAGE", "FULL_WIDTH", "BLANK"
  data       String   // JSON string — flexible per-page content
  customCss  String?  // Untuk Mode Developer: Injeksi CSS Khusus
  customHtml String?  // Untuk Mode Developer: Injeksi HTML Khusus
  lastEditBy String?  // nama admin terakhir yang edit
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ===== MENU — Navigasi Dinamis =====
model Menu {
  id         String   @id @default(cuid())
  label      String   // Nama menu (Misal: "Beranda", "Tentang Kami")
  url        String?  // URL link (Misal: "/tentang-kami/sejarah")
  parentId   String?  // ID dari parent jika ini adalah dropdown
  order      Int      @default(0) // Urutan tampilan (0, 1, 2, dst)
  isDropdown Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Self-relation untuk menu bertingkat
  parent     Menu?    @relation("SubMenus", fields: [parentId], references: [id])
  children   Menu[]   @relation("SubMenus")
}

// ===== MEDIA — Gambar & Video =====
model MediaFile {
  id           String   @id @default(cuid())
  filename     String   
  originalName String   
  mimeType     String   
  size         Int      
  path         String   
  width        Int?     
  height       Int?
  createdAt    DateTime @default(now())
}
